# ── Server ─────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
DEBUG=false

# ── Storage paths ─────────────────────────────────────────────────────
STORAGE_PATH=./storage

# ── Image constraints ─────────────────────────────────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_IMAGE_DIMENSION=2048
WORK_IMAGE_SIZE=1536

# ── Quality control ───────────────────────────────────────────────────
QUALITY_THRESHOLD=0.5
MAX_RETRIES=2
SAVE_DEBUG_ARTIFACTS=false

# ── IDM-VTON path (set in Dockerfile, adjust if running locally) ──────
IDM_VTON_PATH=/app/IDM-VTON

# ── VTON multi-sample & reranking ─────────────────────────────────────
# Number of diffusion samples per job (default 1 for cost, set 3-4 for quality)
VTON_NUM_SAMPLES=1
# Composite score threshold for fallback attempt
VTON_MIN_SCORE=0.55
# Seam blending parameters
VTON_SEAM_FEATHER_PX=11
VTON_SEAM_ERODE_PX=2
# Weight of garment score in composite metric
VTON_GARMENT_WEIGHT=0.5

# ── Preflight input quality gates ───────────────────────────────────────
PREFLIGHT_MIN_DIM=384
PREFLIGHT_BLUR_MIN=40.0
PREFLIGHT_MIN_FACE_AREA=0.003
PREFLIGHT_MIN_PERSON_AREA=0.10
PREFLIGHT_BORDER_CUTOFF_FRAC=0.35

# ── Garment-only super-resolution ─────────────────────────────────────
# Enable SR (requires realesrgan + basicsr + REALESRGAN_WEIGHTS)
VTON_GARMENT_SR=0
VTON_GARMENT_SR_SCALE=2
VTON_GARMENT_SR_PAD=16
VTON_GARMENT_SR_FEATHER=5
# Path to Real-ESRGAN weights (e.g., RealESRGAN_x2plus.pth)
REALESRGAN_WEIGHTS=/path/to/weights.pth

# ── Database (if used) ────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost/dbname
