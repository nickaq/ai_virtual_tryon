// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders    Order[]
  tryOnJobs TryOnJob[]
  sessions  Session[]
  accounts  Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  category    String
  sizes       String // JSON array as string
  colors      String // JSON array as string
  season      String
  composition String
  inStock     Boolean  @default(true)
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])
  status String @default("PENDING")
  total  Float

  contactName String
  email       String
  phone       String
  address     String
  city        String
  postalCode  String
  country     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  order         Order   @relation(fields: [orderId], references: [id])
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int
  selectedSize  String
  selectedColor String
  price         Float
}

model Upload {
  id        String   @id @default(cuid())
  userId    String?
  filename  String
  filepath  String   @unique
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  // Relations
  userJobs    TryOnJob[] @relation("UserImageUpload")
  productJobs TryOnJob[] @relation("ProductImageUpload")
}

model TryOnJob {
  id        String  @id @default(cuid())
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])
  productId String?

  // Image references (file paths via Upload model)
  userImageId    String
  userImage      Upload @relation("UserImageUpload", fields: [userImageId], references: [id])
  productImageId String
  productImage   Upload @relation("ProductImageUpload", fields: [productImageId], references: [id])

  // Processing parameters
  garmentType        String?
  mode               String  @default("final") // 'draft' or 'final'
  realismLevel       Int     @default(3)
  preserveFace       Boolean @default(true)
  preserveBackground Boolean @default(true)

  // Status tracking
  status       String  @default("QUEUED") // QUEUED, PROCESSING, DONE, FAILED
  resultPath   String?
  qualityScore Float?
  errorCode    String?
  errorMessage String?
  retryCount   Int     @default(0)
  maxRetries   Int     @default(2)

  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  startedAt   DateTime?
  completedAt DateTime?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}
